# ─────────────────────────────────────────────────────────────────────────────
# PDF Converter — root .env.example
# Copy to .env and adjust values before running Docker Compose.
# All defaults work out of the box for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend ──────────────────────────────────────────────────────────────────
WEB_PORT=3000

# Must be reachable from the END USER'S BROWSER (not from inside Docker).
# For local dev this is localhost; in production use your public API domain.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend API ───────────────────────────────────────────────────────────────
API_PORT=8000
APP_NAME=PDF Converter API
LOG_LEVEL=INFO

# Comma-separated frontend origins allowed by CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=pdf_converter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433                # host-side port (container always exposes 5432)

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_RAW=raw-documents
MINIO_BUCKET_EXPORTS=excel-exports

# ── Azure Document Intelligence (optional — leave blank to disable) ────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
