# ─────────────────────────────────────────────────────────────────────────────
# PDF Converter Frontend Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL (used by Next.js server-side proxy)
# For local development: http://localhost:8000
# For production on Railway: https://pdf-converter-backend-production-XXXX.up.railway.app
API_URL=http://localhost:8000

# Public API URL (used by browser/client-side code)
# For local development: http://localhost:8000
# For production: /api/backend (relative path to your frontend's proxy endpoint)
NEXT_PUBLIC_API_URL=/api/backend
